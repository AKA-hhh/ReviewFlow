# ============================================================
# ReviewFlow 环境配置
# 复制此文件为 .env 并填写你的 API Key
# ============================================================

# --- DeepSeek API (推荐，兼容 OpenAI 协议) ---
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.deepseek.com

# --- LLM 模型配置 ---
# Pro 模型 — 深度推理任务（结构化提取、分析、综述撰写）
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=30000

# Flash 模型 — 快速任务（关键词提取、引文验证、润色）
FLASH_API_KEY=
FLASH_BASE_URL=https://api.deepseek.com
FLASH_MODEL=deepseek-v4-flash

# HuggingFace (镜像 + 本地模型下载目录)
HF_ENDPOINT=https://hf-mirror.com
HF_HOME=./models/huggingface

# --- Embedding 嵌入模型 ---
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# --- Reranker 重排序模型 ---
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=research_papers

# Search Configuration
SEARCH_MAX_ROUNDS=2
SEARCH_PAPERS_PER_ROUND=25
SEARCH_TEMPERATURE_INITIAL=0.3
SEARCH_TOP_P_INITIAL=0.85
SEARCH_SOURCES=arxiv,semantic_scholar,pubmed,dblp

# arXiv API (可配置镜像或代理地址)
# ARXIV_API_URL=https://export.arxiv.org
ARXIV_TIMEOUT=60

# LLM Concurrency Control
LLM_MAX_CONCURRENT=20

# Relevance Thresholds
RELEVANCE_THRESHOLD_HIGH=0.9
RELEVANCE_THRESHOLD_MID=0.8
RELEVANCE_THRESHOLD_LOW=0.7

# Cache
CACHE_DIR=./cache
CACHE_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
